# Copy this file to .env and fill values.

# Required
OPENAI_API_KEY=sk-proj-your-key-here

# API runtime
ENV=development
LOG_LEVEL=info
API_HOST=0.0.0.0
API_PORT=8000

# Chroma
CHROMA_DIR=data/chroma_db
CHROMA_COLLECTION_NAME=faculty_search
EMBEDDING_MODEL=text-embedding-3-small

# LLM
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=500

# Search tuning
SEARCH_MIN_SCORE_THRESHOLD=0.3
SEARCH_N_RESULTS=5
SEARCH_SEMANTIC_WEIGHT=0.7
SEARCH_KEYWORD_WEIGHT=0.3

# Optional Supabase auth (recommended for production)
SUPABASE_URL=
SUPABASE_KEY=
REQUIRE_SUPABASE=false
